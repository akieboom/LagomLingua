{"id":"alphabet","title":"Alfabet & Uitspraak","icon":"🔤","description":"Leer het Zweedse alfabet en moeilijke klanken","level":"Basis","alphabet":[{"letter":"A","sound":"aa","example":"arm","translation":"arm"},{"letter":"B","sound":"bee","example":"bil","translation":"auto"},{"letter":"C","sound":"see/kee","example":"cykel","translation":"fiets"},{"letter":"D","sound":"dee","example":"dag","translation":"dag"},{"letter":"E","sound":"ee/eh","example":"en","translation":"een"},{"letter":"F","sound":"ef","example":"fisk","translation":"vis"},{"letter":"G","sound":"gee/yee","example":"god","translation":"goed"},{"letter":"H","sound":"hoh","example":"hus","translation":"huis"},{"letter":"I","sound":"ee","example":"is","translation":"ijs"},{"letter":"J","sound":"yod (als 'j' in 'ja')","example":"ja","translation":"ja"},{"letter":"K","sound":"koh/chee","example":"katt","translation":"kat"},{"letter":"L","sound":"el","example":"land","translation":"land"},{"letter":"M","sound":"em","example":"mat","translation":"eten"},{"letter":"N","sound":"en","example":"natt","translation":"nacht"},{"letter":"O","sound":"oo/oh","example":"ost","translation":"kaas"},{"letter":"P","sound":"pee","example":"pojke","translation":"jongen"},{"letter":"Q","sound":"koo","example":"quiz","translation":"quiz"},{"letter":"R","sound":"rollende r","example":"röd","translation":"rood"},{"letter":"S","sound":"es","example":"sol","translation":"zon"},{"letter":"T","sound":"tee","example":"tid","translation":"tijd"},{"letter":"U","sound":"uu (lips vooruit)","example":"ut","translation":"uit"},{"letter":"V","sound":"vee","example":"vind","translation":"wind"},{"letter":"W","sound":"dobbel-vee","example":"weekend","translation":"weekend"},{"letter":"X","sound":"eks","example":"extra","translation":"extra"},{"letter":"Y","sound":"uu-ee","example":"yr","translation":"duizelig"},{"letter":"Z","sound":"zeta","example":"zoo","translation":"dierentuin"},{"letter":"Å","sound":"oh (lang)","example":"år","translation":"jaar"},{"letter":"Ä","sound":"eh (als 'e' in 'bed')","example":"äta","translation":"eten"},{"letter":"Ö","sound":"eu (als 'eu' in 'neus')","example":"öga","translation":"oog"}],"phonetics":[{"rule":"sj, skj, stj","sound":"sj-klank (als 'sh' maar verder achter in keel)","examples":["sjö (meer)","skjuta (schieten)","stjärna (ster)"]},{"rule":"tj, ki, ke, ky, kä, kö","sound":"tj-klank (als 'ch' in 'cheese')","examples":["tjugo (twintig)","kilo","kyla (kou)"]},{"rule":"g voor e, i, y, ä, ö","sound":"j-klank","examples":["ge (geven)","gift (gif/getrouwd)","göra (doen)"]},{"rule":"ng","sound":"ng-klank (als in 'zingen')","examples":["lång (lang)","ung (jong)"]},{"rule":"r + d/l/n/s/t","sound":"retroflexen (tong omhoog)","examples":["bord (tafel)","barn (kind)","märs"]},{"rule":"Toonhoogte (pitch accent)","sound":"Zweeds heeft 2 tonen: acuut (1 piek) en gravis (2 pieken)","examples":["anden (de eend) vs anden (de geest)","buren (de buur) vs buren (geburen)"]}],"words":[]}